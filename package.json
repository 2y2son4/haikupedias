{
  "name": "haikupedias",
  "version": "1.0.0",
  "description": "Algorithmic poetry and music generator",
  "scripts": {
    "start": "nx serve haikupedias-shell --open",
    "build": "nx build haikupedias-shell",
    "build:all": "nx run-many --target=build --all",
    "build:prod": "nx build haikupedias-shell --configuration production",
    "build:prod:stats": "nx build haikupedias-shell --configuration production --stats-json",
    "bundle:report": "node scripts/report-bundle-stats.mjs",
    "test": "nx run-many --target=test --projects=components,design-tokens",
    "lint": "nx lint"
  },
  "keywords": [
    "poetry",
    "music",
    "algorithmic-composition",
    "angular",
    "nx",
    "satie",
    "haiku",
    "dodecaphonic"
  ],
  "author": "",
  "license": "ISC",
