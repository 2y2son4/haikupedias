{
  "servers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "angular-cli": {
      "command": "npx",
      "args": ["-y", "@angular/cli"],
      "type": "stdio"
    },
    "angular-docs": {
      "command": "npx",
      "args": ["angular-mcp-server"]
    },
    "nx-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": ["nx-mcp@latest"]
    }
  },
  "inputs": []
}
